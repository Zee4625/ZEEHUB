local rainbowHue = 0

-- Team detection
local function getTeam()
    local character = LocalPlayer.Character
    if not character then return nil end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return nil end
    local team = humanoid:GetAttribute("Team")
    if team then return team end
    local playerTeam = LocalPlayer.Team
    if playerTeam then return playerTeam.Name end
    return nil
end

local function getPlayerTeam(player)
    local character = player.Character
    if not character then return nil end
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return nil end
    local team = humanoid:GetAttribute("Team")
    if team then return team end
    local playerTeam = player.Team
    if playerTeam then return playerTeam.Name end
    return nil
end

local function isTeammate(player)
    local myTeam = getTeam()
    local theirTeam = getPlayerTeam(player)
    if myTeam and theirTeam then
        return myTeam == theirTeam
    end
    return false
end

local function updateRainbow()
    if espRainbowMode then
        rainbowHue = (rainbowHue + 0.01) % 1
        local rainbowColor = Color3.fromHSV(rainbowHue, 1, 1)
        espBoxColor = rainbowColor
        espTracerColor = rainbowColor
        espSnaplineColor = rainbowColor
    end
end

local function createESP(player)
    if player == LocalPlayer then return end
    if espDrawings[player] then
        for _, obj in pairs(espDrawings[player]) do
            pcall(function() obj:Remove() end)
        end
    end

    local Box = Drawing.new("Square")
    Box.Visible = false
    Box.Color = espBoxColor
    Box.Thickness = espBoxThickness
    Box.Transparency = 1
    Box.Filled = false

    local Tracer = Drawing.new("Line")
    Tracer.Visible = false
    Tracer.Color = espTracerColor
    Tracer.Thickness = espTracerThickness

    local NameTag = Drawing.new("Text")
    NameTag.Visible = false
    NameTag.Color = espNameColor
    NameTag.Size = espNameSize
    NameTag.Center = true
    NameTag.Outline = true
    NameTag.OutlineColor = Color3.fromRGB(0, 0, 0)

    local DistanceTag = Drawing.new("Text")
    DistanceTag.Visible = false
    DistanceTag.Color = espDistanceColor
    DistanceTag.Size = 10
    DistanceTag.Center = true
    DistanceTag.Outline = true
    DistanceTag.OutlineColor = Color3.fromRGB(0, 0, 0)

    local HealthBar = Drawing.new("Line")
    HealthBar.Visible = false
    HealthBar.Color = Color3.fromRGB(0, 255, 0)
    HealthBar.Thickness = espHealthBarThickness

    local HeadDot = Drawing.new("Circle")
    HeadDot.Visible = false
    HeadDot.Color = espBoxColor
    HeadDot.Thickness = espHeadDotSize
    HeadDot.Radius = espHeadDotSize / 2
    HeadDot.Filled = true

    local Snapline = Drawing.new("Line")
    Snapline.Visible = false
    Snapline.Color = espSnaplineColor
    Snapline.Thickness = 1

    espDrawings[player] = {
        Box = Box, Tracer = Tracer, NameTag = NameTag, DistanceTag = DistanceTag,
        HealthBar = HealthBar, HeadDot = HeadDot, Snapline = Snapline
    }
end

local function removeESP(player)
    local data = espDrawings[player]
    if data then
        pcall(function() data.Box:Remove() end)
        pcall(function() data.Tracer:Remove() end)
        pcall(function() data.NameTag:Remove() end)
        pcall(function() data.DistanceTag:Remove() end)
        pcall(function() data.HealthBar:Remove() end)
        pcall(function() data.HeadDot:Remove() end)
        pcall(function() data.Snapline:Remove() end)
        espDrawings[player] = nil
    end
end

local function updateESP()
    updateRainbow()

    if not espEnabled then
        for _, data in pairs(espDrawings) do
            if data then
                data.Box.Visible = false
                data.Tracer.Visible = false
                data.NameTag.Visible = false
                data.DistanceTag.Visible = false
                data.HealthBar.Visible = false
                data.HeadDot.Visible = false
                data.Snapline.Visible = false
            end
        end
        return
    end

    local viewport = Camera.ViewportSize
    local center = Vector2.new(viewport.X / 2, viewport.Y)

    for player, data in pairs(espDrawings) do
        if player == LocalPlayer then continue end

        local char = player.Character
        if not char then
            data.Box.Visible = false data.Tracer.Visible = false
            data.NameTag.Visible = false data.DistanceTag.Visible = false
            data.HealthBar.Visible = false data.HeadDot.Visible = false
            data.Snapline.Visible = false
            continue
        end

        local humanoid = char:FindFirstChild("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")

        if not humanoid or not rootPart or humanoid.Health <= 0 then
            data.Box.Visible = false data.Tracer.Visible = false
            data.NameTag.Visible = false data.DistanceTag.Visible = false
            data.HealthBar.Visible = false data.HeadDot.Visible = false
            data.Snapline.Visible = false
            continue
        end

        local distance = (Camera.CFrame.Position - rootPart.Position).Magnitude
        if distance > espMaxDistance then
            data.Box.Visible = false data.Tracer.Visible = false
            data.NameTag.Visible = false data.DistanceTag.Visible = false
            data.HealthBar.Visible = false data.HeadDot.Visible = false
            data.Snapline.Visible = false
            continue
        end

        local pos, onScreen = Camera:worldToViewportPoint(rootPart.Position)
        local teamColor = espTeamColorEnabled and (isTeammate(player) and espTeamColor or espEnemyColor) or espBoxColor

        local head = char:FindFirstChild("Head")
        local headPos = head and Camera:worldToViewportPoint(head.Position) or pos
        local legPos = Camera:worldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))

        local boxHeight = headPos.Y - legPos.Y
        local boxWidth = boxHeight * 0.5

        if espBoxEnabled and onScreen then
            data.Box.Size = Vector2.new(boxWidth, boxHeight)
            data.Box.Position = Vector2.new(pos.X - boxWidth/2, legPos.Y)
            data.Box.Color = teamColor
            data.Box.Thickness = espBoxThickness
            data.Box.Visible = true
        else
            data.Box.Visible = false
        end

        if espHealthBarEnabled and onScreen then
            local health = humanoid.Health / humanoid.MaxHealth
            local barX = data.Box.Position.X + data.Box.Size.X + 5
            local barY = data.Box.Position.Y
            local barHeight = data.Box.Size.Y
            data.HealthBar.From = Vector2.new(barX, barY + barHeight * (1 - health))
            data.HealthBar.To = Vector2.new(barX, barY + barHeight)
            data.HealthBar.Color = Color3.new(1 - health, health, 0)
            data.HealthBar.Thickness = espHealthBarThickness
            data.HealthBar.Visible = true
        else
            data.HealthBar.Visible = false
        end

        if espNameEnabled and onScreen then
            data.NameTag.Position = Vector2.new(pos.X, data.Box.Position.Y - 15)
            data.NameTag.Text = player.Name
            data.NameTag.Color = teamColor
            data.NameTag.Size = espNameSize
            data.NameTag.Visible = true
        else
            data.NameTag.Visible = false
        end

        if espDistanceEnabled and onScreen then
            data.DistanceTag.Position = Vector2.new(pos.X, data.Box.Position.Y + data.Box.Size.Y + 5)
            data.DistanceTag.Text = math.floor(distance) .. "m"
            data.DistanceTag.Size = 10
            data.DistanceTag.Visible = true
        else
            data.DistanceTag.Visible = false
        end

        if espHeadDotEnabled and head and onScreen then
            data.HeadDot.Position = Vector2.new(headPos.X, headPos.Y)
            data.HeadDot.Color = teamColor
            data.HeadDot.Visible = true
        else
            data.HeadDot.Visible = false
        end

        if espSnaplinesEnabled then
            data.Snapline.From = Vector2.new(center.X, center.Y + 50)
            data.Snapline.To = Vector2.new(pos.X, pos.Y)
            data.Snapline.Color = teamColor
            data.Snapline.Visible = true
        else
            data.Snapline.Visible = false
        end

        if espTracerEnabled then
            data.Tracer.From = Vector2.new(center.X, center.Y)
            data.Tracer.To = Vector2.new(pos.X, pos.Y)
            data.Tracer.Color = teamColor
            data.Tracer.Thickness = espTracerThickness
            data.Tracer.Visible = true
        else
            data.Tracer.Visible = false
        end
    end
end

RunService.RenderStepped:Connect(updateESP)

for _, plr in pairs(Players:GetPlayers()) do
    if plr ~= LocalPlayer then createESP(plr) end
end

Players.PlayerAdded:Connect(function(plr)
    if plr ~= LocalPlayer then createESP(plr) end
end)
Players.PlayerRemoving:Connect(removeESP)

